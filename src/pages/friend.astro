---
import Layout from '~/layouts/Layout.astro'
import PageIntro from '~/components/PageIntro.astro'
import GiscusLoader from '~/components/GiscusLoader.astro'
import DividerText from '~/components/DividerText.astro'
import siteConfig from '~/site.config'
import ChevronsRight from '~/icons/chevrons-right.svg'

// 友站連結資料
const friendLinks = [
  {
    name: 'bob 的 Blog',
    avatar: 'https://blog.bob0623.net/avatar.jpg',
    description: 'bob的Blog',
    url: 'https://blog.bob0623.net/',
  },
  {
    name: '呂老闆',
    avatar: 'https://ricky.place/images/profile.jpg',
    description: '呂大老闆',
    url: 'https://ricky.place/',
  },
  {
    name: '第三夏尔',
    avatar: 'https://thirdshire.com/blackcat_avatar.jpg',
    description: '认真生活，积极摸鱼',
    url: 'https://thirdshire.com/',
  },
  {
    name: '元元',
    avatar: 'https://yuan-tw.net/images/2.jfif',
    description: '元元的網站',
    url: 'https://yuan-tw.net/',
  },
  {
    name: 'n1cat',
    avatar: 'https://api.n1cat.xyz/api/v2/objects/avatar/f05glkbbc2o13i0fmr.jpg',
    description: 'my first blog ><',
    url: 'https://n1cat.xyz',
  },
  {
    name: 'yimang',
    avatar: 'https://yimang.tw/images/avatar.webp',
    description: '一個高中生',
    url: 'https://yimang.tw',
  },
  {
    name: 'Osga',
    avatar: 'https://avatars.githubusercontent.com/u/84913645?v=4',
    description: '資安電神',
    url: 'https://www.osga.dev/',
  },
  {
    name: 'sangege',
    avatar: 'https://www.gravatar.com/avatar/f6d0a62624d1d82d90ea3232e3663561?s=512',
    description: '三哥',
    url: 'https://sange.ge',
  },
  {
    name: 'bc',
    avatar: '/friends/bc.png',
    description: '直升機',
    url: 'https://bcxy.me/',
  },
  {
    name: 'nelson',
    avatar:
      'https://github.com/nelsonGX/Nelson-Website/blob/main/public/assets/images/nelsongx.png?raw=true',
    description: '介紹：大帥哥(他自己打的)',
    url: 'https://nelsongx.com/',
  },
]
---

<Layout
  title="友站連結"
  description="整理 CHIEN 推薦的友站連結與交流資訊。"
  pageType="page"
  noindex
  wide
>
  <PageIntro
    eyebrow="Community"
    title="友站連結"
    description="一些值得追蹤的個人網站與技術部落格。網路不只有平台，也由彼此連結的獨立網站組成。"
    meta={`${friendLinks.length} 個友站`}
  />

  <section class="py-10 sm:py-14" aria-label="友站列表">
    <!-- 友站連結列表 -->
    <div class="grid gap-3 sm:grid-cols-2">
      {
        friendLinks.map((friend, index) => (
          <a
            href={friend.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex min-h-24 items-center gap-4 rounded-lg border border-foreground/10 p-5 no-underline transition-colors hover:border-accent/35"
          >
            {friend.avatar && (
              <div class="relative flex size-12 shrink-0 items-center justify-center overflow-hidden rounded-full border border-foreground/10 bg-foreground/5 font-mono text-sm font-semibold text-foreground/65">
                <span aria-hidden="true">{friend.name.charAt(0).toUpperCase()}</span>
                <img
                  src={friend.avatar}
                  alt={friend.name}
                  loading={index < 4 ? 'eager' : 'lazy'}
                  class="absolute inset-0 size-full object-cover"
                  onerror="this.style.display='none'"
                />
              </div>
            )}
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-foreground transition-colors group-hover:text-accent">
                {friend.name}
              </div>
              {friend.description && (
                <div class="mt-1 truncate text-sm text-foreground/65">
                  {friend.description}
                </div>
              )}
            </div>
            <ChevronsRight class="size-5 shrink-0 text-foreground/45 transition-all group-hover:translate-x-1 group-hover:text-accent" />
          </a>
        ))
      }
    </div>

    <!-- 友站申請說明 -->
    <div
      class="mt-12 grid gap-6 border-t border-foreground/10 pt-10 md:grid-cols-[14rem_minmax(0,1fr)] md:gap-12"
    >
      <div>
        <p class="mb-3 font-mono text-xs font-semibold uppercase text-accent">Exchange</p>
        <h2 class="text-xl font-bold text-foreground">友站申請</h2>
      </div>
      <div class="max-w-2xl space-y-4 text-foreground/68">
        <p>想出現在上面的話，請在下方留言區留下網站標題、描述、圖片連結與網站網址。</p>
        <p>
          本站頭像可以使用 <a href="https://blog.chien.dev/avatar.jpg"
            >blog.chien.dev/avatar.jpg</a
          >。如果沒有提供描述，我會瀏覽網站後協助補上。
        </p>
      </div>
    </div>
  </section>

  <!-- 留言區 -->
  {
    siteConfig.giscus && (
      <section class="mx-auto mt-8 w-full max-w-3xl">
        <DividerText text="留言與申請" />
        <GiscusLoader />
      </section>
    )
  }
</Layout>
