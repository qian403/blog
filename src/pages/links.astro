---
import Layout from '~/layouts/Layout.astro'
import PageIntro from '~/components/PageIntro.astro'
import ChevronsRight from '~/icons/chevrons-right.svg'

const linkGroups = [
  {
    title: 'Social',
    description: '平常分享近況與技術內容的平台。',
    links: [
      { name: 'GitHub', detail: '@qian403', url: 'https://github.com/qian403' },
      { name: 'Telegram', detail: '@qian50', url: 'https://t.me/qian50' },
      {
        name: 'Instagram',
        detail: '@qian40_',
        url: 'https://www.instagram.com/chien40_/',
      },
    ],
  },
  {
    title: 'Contact',
    description: '需要討論合作或技術問題時，可以從這裡找到我。',
    links: [
      { name: 'Email', detail: 'hi@chien.dev', url: 'mailto:hi@chien.dev' },
      { name: 'Discord', detail: 'qian_30', url: undefined },
    ],
  },
  {
    title: 'Projects',
    description: '我維護中的其他網站與小型服務。',
    links: [
      { name: 'CHIEN Tools', detail: 'tools.chien.dev', url: 'https://tools.chien.dev' },
    ],
  },
]
---

<Layout
  title="社群與聯絡方式"
  description="整理 CHIEN 的社群平台、聯絡方式與其他網站連結，方便快速找到 GitHub、Email 與常用服務。"
  pageType="page"
  noindex
  wide
>
  <PageIntro
    eyebrow="Directory"
    title="社群與聯絡方式"
    description="社群帳號、聯絡方式，以及我維護中的其他網站。"
  />

  <div class="divide-y divide-foreground/10">
    {
      linkGroups.map((group) => (
        <section
          class="grid gap-7 py-10 sm:py-12 md:grid-cols-[14rem_minmax(0,1fr)] md:gap-12"
          aria-labelledby={`links-${group.title.toLowerCase()}`}
        >
          <div>
            <h2
              id={`links-${group.title.toLowerCase()}`}
              class="text-xl font-bold text-foreground"
            >
              {group.title}
            </h2>
            <p class="mt-3 text-sm/6 text-foreground/65">{group.description}</p>
          </div>
          <ul class="border-t border-foreground/10">
            {group.links.map((link) => (
              <li class="border-b border-foreground/10">
                {link.url ? (
                  <a
                    href={link.url}
                    target={link.url.startsWith('http') ? '_blank' : undefined}
                    rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
                    class="group flex min-h-20 items-center justify-between gap-5 py-4 no-underline"
                  >
                    <span>
                      <span class="block font-semibold text-foreground transition-colors group-hover:text-accent">
                        {link.name}
                      </span>
                      <span class="mt-1 block text-sm text-foreground/65">
                        {link.detail}
                      </span>
                    </span>
                    <ChevronsRight class="size-5 shrink-0 text-foreground/45 transition-all group-hover:translate-x-1 group-hover:text-accent" />
                  </a>
                ) : (
                  <div class="flex min-h-20 items-center justify-between gap-5 py-4">
                    <span>
                      <span class="block font-semibold text-foreground">{link.name}</span>
                      <span class="mt-1 block text-sm text-foreground/65">
                        {link.detail}
                      </span>
                    </span>
                    <span class="font-mono text-xs text-foreground/65">
                      Direct message
                    </span>
                  </div>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</Layout>
