---
import type { GetStaticPaths } from 'astro'
import Layout from '~/layouts/Layout.astro'
import { getSortedPosts } from '~/utils'
import Pagination from '~/components/Pagination.astro'
import siteConfig from '~/site.config'
import PostPreview from '~/components/PostPreview.astro'
import PageHeader from '~/components/PageHeader.astro'

// Note: Pagination like '/', '/2', '/3' only works with spread param like [...page]
export const getStaticPaths = (async ({ paginate }) => {
  const sortedPosts = await getSortedPosts()
  return paginate(sortedPosts.reverse(), { pageSize: siteConfig.pageSize })
}) satisfies GetStaticPaths

const { page } = Astro.props
const pageTitle = page.currentPage > 1 ? `文章彙整（第 ${page.currentPage} 頁）` : '文章彙整'
const pageDescription =
  page.currentPage > 1
    ? `第 ${page.currentPage} 頁的技術文章彙整，收錄網路技術、資訊安全、BGP、DevOps 與 Linux 主題文章。`
    : '技術文章彙整，收錄網路技術、資訊安全、BGP、DevOps 與 Linux 主題文章。'
const breadcrumbs = [
  { name: '首頁', item: siteConfig.site },
  { name: '文章', item: `${siteConfig.site}/posts/` },
]
if (page.currentPage > 1) {
  breadcrumbs.push({
    name: `第 ${page.currentPage} 頁`,
    item: new URL(page.url.current, Astro.site).href,
  })
}
const itemList = page.data.map((post, index) => ({
  name: post.data.title,
  url: new URL(`/posts/${post.id}`, Astro.site).href,
  position: index + 1,
}))
---

<Layout
  title={pageTitle}
  description={pageDescription}
  pageType="collection"
  noindex={page.currentPage > 1}
  breadcrumbs={breadcrumbs}
  itemList={itemList}
>
  {page.url.prev && <link rel="prev" href={page.url.prev} slot="head" />}
  {page.url.next && <link rel="next" href={page.url.next} slot="head" />}
  <div class="mt-2 sm:mt-0">
    <PageHeader />
    {page.data.map((post) => <PostPreview post={post} />)}
    <Pagination
      prevLink={page.url.prev ? page.url.prev : undefined}
      prevText="Newer Posts"
      nextLink={page.url.next ? page.url.next : undefined}
      nextText="Older Posts"
    />
  </div>
</Layout>
