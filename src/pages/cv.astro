---
import Layout from '~/layouts/Layout.astro'

const workExperience = [
  {
    title: '實習工程師',
    company: '瀚霖智動銷售科技有限公司',
    department: '系統維運與安全部門',
    summary: '負責系統維運、資訊安全，以及全端開發。',
    focus: ['系統維運', '資訊安全', '前後端開發'],
    start: '2024-11',
    end: null as string | null,
  },
  {
    title: '實習網路管理工程師',
    company: '一三五有限公司',
    department: '電腦部門',
    summary: '參與企業網路環境、設備與日常資訊系統的管理維護。',
    focus: ['網路管理', '設備維護', '技術支援'],
    start: '2020-07',
    end: '2023-08',
  },
]

const education = [
  {
    school: '國立宜蘭大學',
    department: '資訊工程系',
    start: '2024-09',
    end: null as string | null,
  },
  {
    school: '國立羅東高工',
    department: '資訊科',
    start: '2021-09',
    end: '2023-06',
  },
]

const certifications = [
  {
    name: 'iPAS 資訊安全工程師',
    level: '中級能力鑑定',
    issuer: '經濟部產業發展署',
    year: '2025',
  },
  {
    name: '網路架設乙級技術士',
    level: '',
    issuer: '勞動部勞動力發展署',
    year: '2023',
  },
  {
    name: '電腦硬體裝修乙級技術士',
    level: '',
    issuer: '勞動部勞動力發展署',
    year: '2022',
  },
]

const skillGroups = [
  {
    name: 'Programming',
    skills: ['Python', 'JavaScript', 'TypeScript', 'C++', 'C#', 'Go', 'Swift'],
  },
  {
    name: 'Web',
    skills: ['Vue.js', 'React', 'Django', 'Tailwind CSS'],
  },
  {
    name: 'Systems',
    skills: ['Linux', 'Windows', 'Docker', 'Git', 'Nginx'],
  },
  {
    name: 'Network & Security',
    skills: ['BGP', '網路維運', '系統維運', '資訊安全'],
  },
]

const projects = [
  {
    name: 'AS215934 自治系統',
    description: '運營個人自治系統，實踐 BGP 路由協議與網路架構設計。',
    stack: 'BGP / Network Operations',
    href: 'https://bgp.tools/as/215934',
    linkLabel: 'BGP Tools',
  },
  {
    name: 'FutureNest Chatbot',
    description: '支援文件索引與多供應商 LLM 回退的 RAG 文件檢索聊天機器人。',
    stack: 'Django / React / Chroma / Docker',
    href: 'https://github.com/qian403/futurenest-chatbot',
    linkLabel: 'GitHub',
  },
  {
    name: 'NIU-app',
    description: '整合校務系統、Moodle、課表與行事曆的宜蘭大學校園 App。',
    stack: 'Swift / SwiftUI / UIKit / WidgetKit',
    href: 'https://github.com/qian403/NIU-app',
    linkLabel: 'GitHub',
  },
  {
    name: 'Web Tools',
    description: '以 Vue 開發的實用網頁工具集合。',
    stack: 'Vue.js',
    href: 'https://github.com/qian403/web-tools',
    linkLabel: 'GitHub',
  },
]

const leadership = [
  { name: 'SITCON 學生計算機年會 2026', role: '總召', year: '2026' },
  { name: 'SITCON Camp 2025', role: '副召', year: '2025' },
  { name: 'SITCON 學生計算機年會 2025', role: '行政組副組長', year: '2025' },
  { name: 'SITCON 學生計算機年會 2024', role: '場務組志工', year: '2024' },
]

const additionalExperience = [
  { name: 'AWS STEM Summer Camp on The Cloud', year: '2023' },
  { name: '教育部先進資通安全實務人才培育計畫', year: '2023' },
  { name: 'AIS3 Junior', year: '2022' },
  { name: '一日資安體驗營', role: '助教', year: '2023' },
  { name: '羅東高工資訊研究社', role: '副社長', year: '2021-2023' },
]

function formatDate(date: string | null): string {
  if (!date) return 'Present'
  const [year, month] = date.split('-')
  return month ? `${year}.${month}` : year
}
---

<Layout
  title="CHIEN 履歷"
  description="CHIEN 的履歷，整理資訊工程背景、實習經歷、資訊安全、網路技術、BGP 與系統維運相關能力。"
  pageType="profile"
  wide
>
  <div
    class="cv-toolbar mx-auto flex w-full max-w-[210mm] items-center justify-between gap-5 py-7"
  >
    <div>
      <p class="font-mono text-xs font-semibold uppercase text-accent">
        Curriculum Vitae
      </p>
      <p class="mt-1 text-xs text-foreground/55">Last updated / 2026.07</p>
    </div>
    <button
      type="button"
      data-print-cv
      class="min-h-10 border border-foreground/18 px-4 py-2 text-sm font-semibold text-foreground transition-colors hover:border-accent/55 hover:text-accent"
    >
      列印 / 儲存 PDF
    </button>
  </div>

  <article class="cv-paper">
    <header class="cv-header border-b border-[#d4d4d8] pb-4">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h1 class="text-[2rem] font-bold leading-none text-[#111827]">徐嘉謙</h1>
          <p class="mt-2 text-lg font-semibold text-[#2563eb]">CHIEN</p>
          <p class="mt-3 text-[0.6875rem] font-semibold uppercase text-[#4b5563]">
            Network / Security / Systems Engineer
          </p>
        </div>

        <address class="not-italic text-[0.6875rem]/5 text-[#374151] sm:text-right">
          <p>Yilan, Taiwan · GMT+8</p>
          <p><a href="mailto:hi@chien.dev">hi@chien.dev</a></p>
          <p><a href="https://github.com/qian403">github.com/qian403</a></p>
          <p><a href="https://t.me/qian50">t.me/qian50</a></p>
        </address>
      </div>

      <p class="mt-4 border-l-2 border-[#2563eb] pl-4 text-[0.75rem]/5 text-[#374151]">
        資訊工程學生，具備企業系統維運、網路管理、資訊安全與全端開發實務經驗。運營個人自治系統
        AS215934，持續投入 BGP 路由、可靠系統與資安領域。
      </p>
    </header>

    <div
      class="cv-columns mt-4 grid gap-7 sm:grid-cols-[minmax(0,0.82fr)_minmax(0,1.9fr)]"
    >
      <aside class="space-y-5 sm:border-r sm:border-[#e4e4e7] sm:pr-6">
        <section class="cv-section" aria-labelledby="education-heading">
          <h2 id="education-heading" class="cv-heading">Education</h2>
          <div class="mt-3 space-y-4">
            {
              education.map((item) => (
                <div class="cv-entry">
                  <h3 class="text-[0.75rem] font-bold text-[#111827]">{item.school}</h3>
                  <p class="mt-0.5 text-[0.6875rem] font-semibold text-[#2563eb]">
                    {item.department}
                  </p>
                  <p class="mt-1 text-[0.625rem] text-[#6b7280]">
                    {formatDate(item.start)} - {formatDate(item.end)}
                  </p>
                </div>
              ))
            }
          </div>
        </section>

        <section class="cv-section" aria-labelledby="certifications-heading">
          <h2 id="certifications-heading" class="cv-heading">Certifications</h2>
          <div class="mt-3 space-y-3.5">
            {
              certifications.map((certification) => (
                <div class="cv-entry">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="text-[0.6875rem]/4 font-bold text-[#111827]">
                      {certification.name}
                    </h3>
                    <span class="shrink-0 text-[0.625rem] font-semibold text-[#2563eb]">
                      {certification.year}
                    </span>
                  </div>
                  {certification.level && (
                    <p class="mt-0.5 text-[0.625rem] font-semibold text-[#4b5563]">
                      {certification.level}
                    </p>
                  )}
                  <p class="mt-0.5 text-[0.625rem]/4 text-[#6b7280]">
                    {certification.issuer}
                  </p>
                </div>
              ))
            }
          </div>
        </section>

        <section class="cv-section" aria-labelledby="skills-heading">
          <h2 id="skills-heading" class="cv-heading">Technical Skills</h2>
          <dl class="mt-3 space-y-3.5">
            {
              skillGroups.map((group) => (
                <div class="cv-entry">
                  <dt class="text-[0.625rem] font-bold uppercase text-[#2563eb]">
                    {group.name}
                  </dt>
                  <dd class="mt-1 text-[0.6875rem]/5 text-[#374151]">
                    {group.skills.join(' · ')}
                  </dd>
                </div>
              ))
            }
          </dl>
        </section>
      </aside>

      <div class="min-w-0 space-y-4">
        <section class="cv-section" aria-labelledby="experience-heading">
          <h2 id="experience-heading" class="cv-heading">Work Experience</h2>
          <div class="mt-3 space-y-4">
            {
              workExperience.map((job) => (
                <div class="cv-entry">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="text-[0.8125rem] font-bold text-[#111827]">
                        {job.title}
                      </h3>
                      <p class="mt-0.5 text-[0.6875rem] font-semibold text-[#2563eb]">
                        {job.company}
                      </p>
                    </div>
                    <p class="shrink-0 text-right text-[0.625rem] font-semibold text-[#4b5563]">
                      {formatDate(job.start)} - {formatDate(job.end)}
                    </p>
                  </div>
                  <p class="mt-1 text-[0.625rem] text-[#6b7280]">{job.department}</p>
                  <p class="mt-2 text-[0.6875rem]/5 text-[#374151]">{job.summary}</p>
                  <p class="mt-1.5 text-[0.625rem]/4 text-[#6b7280]">
                    {job.focus.join(' / ')}
                  </p>
                </div>
              ))
            }
          </div>
        </section>

        <section class="cv-section" aria-labelledby="projects-heading">
          <h2 id="projects-heading" class="cv-heading">Selected Projects</h2>
          <div class="mt-3 grid gap-x-6 gap-y-3 sm:grid-cols-2">
            {
              projects.map((project) => (
                <div class="cv-entry border-t border-[#e4e4e7] pt-2.5">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="text-[0.75rem] font-bold text-[#111827]">
                      {project.name}
                    </h3>
                    <a
                      href={project.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`查看 ${project.name}`}
                      class="shrink-0 text-[0.6875rem] no-underline"
                    >
                      {project.linkLabel}
                    </a>
                  </div>
                  <p class="mt-1.5 text-[0.6875rem]/5 text-[#374151]">
                    {project.description}
                  </p>
                  <p class="mt-1 text-[0.625rem]/4 text-[#6b7280]">{project.stack}</p>
                </div>
              ))
            }
          </div>
        </section>

        <section class="cv-section" aria-labelledby="leadership-heading">
          <h2 id="leadership-heading" class="cv-heading">Leadership & Community</h2>
          <div class="mt-3 space-y-2.5">
            {
              leadership.map((item) => (
                <div class="cv-entry grid grid-cols-[minmax(0,1fr)_auto] gap-4">
                  <p class="text-[0.6875rem]/5 text-[#374151]">
                    <strong class="font-bold text-[#111827]">{item.name}</strong>
                    <span class="ml-1.5 text-[#2563eb]">/ {item.role}</span>
                  </p>
                  <time class="text-[0.625rem] font-semibold text-[#6b7280]">
                    {item.year}
                  </time>
                </div>
              ))
            }
          </div>
        </section>

        <section class="cv-section" aria-labelledby="training-heading">
          <h2 id="training-heading" class="cv-heading">
            Additional Training & Activities
          </h2>
          <div class="mt-3 grid gap-x-6 gap-y-2 sm:grid-cols-2">
            {
              additionalExperience.map((item) => (
                <div class="cv-entry grid grid-cols-[minmax(0,1fr)_auto] gap-3 border-t border-[#e4e4e7] pt-2">
                  <p class="text-[0.6875rem]/5 text-[#374151]">
                    <strong class="font-semibold text-[#111827]">{item.name}</strong>
                    {item.role && (
                      <span class="ml-1.5 text-[#2563eb]">/ {item.role}</span>
                    )}
                  </p>
                  <time class="text-[0.625rem] font-semibold text-[#6b7280]">
                    {item.year}
                  </time>
                </div>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </article>
</Layout>

<script>
  document
    .querySelector<HTMLButtonElement>('[data-print-cv]')
    ?.addEventListener('click', () => {
      window.print()
    })
</script>

<style>
  .cv-paper {
    width: min(210mm, 100%);
    min-height: 297mm;
    margin: 0 auto 4rem;
    padding: 14mm 15mm;
    background: #fff;
    color: #18181b;
    font-family:
      -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang TC', 'Noto Sans TC',
      'Microsoft JhengHei', sans-serif;
    letter-spacing: 0;
    box-shadow: 0 18px 60px rgb(0 0 0 / 18%);
  }

  .cv-paper a {
    color: #1d4ed8;
    text-underline-offset: 2px;
  }

  .cv-heading {
    border-bottom: 1px solid #d4d4d8;
    padding-bottom: 0.35rem;
    color: #111827;
    font-size: 0.75rem;
    font-weight: 800;
    line-height: 1.25rem;
    text-transform: uppercase;
  }

  @media (max-width: 639px) {
    .cv-toolbar {
      padding-inline: 0;
    }

    .cv-paper {
      min-height: 0;
      margin-inline: calc(var(--spacing) * -5);
      margin-bottom: 2rem;
      width: auto;
      padding: 2rem 1.25rem;
      box-shadow: none;
    }

    .cv-paper :is(p, address, li, dd, time) {
      font-size: 0.75rem !important;
      line-height: 1.35rem !important;
    }

    .cv-paper :is(h3, dt, .cv-heading) {
      font-size: 0.8125rem !important;
      line-height: 1.35rem !important;
    }
  }

  @media print {
    @page {
      size: A4;
      margin: 8mm 12mm;
    }

    :global(.site-header),
    :global(footer),
    .cv-toolbar {
      display: none !important;
    }

    :global(html),
    :global(body),
    :global(.site-shell) {
      background: #fff !important;
      color: #18181b !important;
    }

    :global(.site-shell) {
      display: block !important;
      max-width: none !important;
      min-height: 0 !important;
      padding: 0 !important;
    }

    :global(main) {
      display: block !important;
    }

    .cv-paper {
      width: auto;
      min-height: 0;
      margin: 0;
      padding: 0;
      box-shadow: none;
      print-color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }

    .cv-columns {
      grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.9fr) !important;
    }

    .cv-section,
    .cv-entry {
      break-inside: avoid;
    }

    .cv-paper a {
      color: #1d4ed8 !important;
    }
  }
</style>
