---
import Layout from '~/layouts/Layout.astro'
---

<Layout title="404 Not Found" noindex>
  <div class="not-found">
    <canvas id="particles"></canvas>
    <div class="content">
      <h1 class="glitch" data-text="404">404</h1>
      <p class="subtitle">找不到這個頁面</p>
      <p class="hint">看起來你迷路了，這裡什麼都沒有</p>
      <div class="actions">
        <a href="/" class="button">回首頁</a>
        <a href="/posts/" class="button">文章列表</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .not-found {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    overflow: hidden;
  }

  #particles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  /* Glitch effect */
  .glitch {
    font-size: clamp(6rem, 20vw, 12rem);
    font-weight: 900;
    color: var(--theme-accent);
    position: relative;
    animation: float 3s ease-in-out infinite;
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0.8;
  }

  .glitch::before {
    color: var(--theme-accent);
    animation: glitch-1 4s infinite linear alternate-reverse;
    clip-path: polygon(0 0, 100% 0, 100% 33%, 0 33%);
  }

  .glitch::after {
    color: var(--theme-accent);
    animation: glitch-2 4s infinite linear alternate-reverse;
    clip-path: polygon(0 67%, 100% 67%, 100% 100%, 0 100%);
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--theme-foreground);
    opacity: 0.7;
    animation: fade-in 1s ease-out 0.3s both;
  }

  .hint {
    font-size: 0.9rem;
    color: var(--theme-foreground);
    opacity: 0.4;
    animation: fade-in 1s ease-out 0.6s both;
  }

  .actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    animation: fade-in 1s ease-out 0.9s both;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @keyframes glitch-1 {
    0%, 92% { transform: translate(0); }
    93% { transform: translate(-8px, -2px); }
    94% { transform: translate(4px, 1px); }
    95% { transform: translate(-3px, -1px); }
    96% { transform: translate(6px, 2px); }
    97% { transform: translate(-2px, 1px); }
    98% { transform: translate(5px, -1px); }
    99% { transform: translate(-4px, 2px); }
    100% { transform: translate(0); }
  }

  @keyframes glitch-2 {
    0%, 90% { transform: translate(0); }
    91% { transform: translate(6px, 1px); }
    92% { transform: translate(-3px, -2px); }
    93% { transform: translate(5px, 1px); }
    94% { transform: translate(-6px, -1px); }
    95% { transform: translate(3px, 2px); }
    96% { transform: translate(-4px, -1px); }
    97% { transform: translate(7px, 1px); }
    98% { transform: translate(-2px, -2px); }
    99% { transform: translate(4px, 1px); }
    100% { transform: translate(0); }
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const canvas = document.getElementById('particles') as HTMLCanvasElement
  if (canvas) {
    const ctx = canvas.getContext('2d')!
    let w = 0
    let h = 0
    let particles: Array<{
      x: number; y: number; r: number
      vx: number; vy: number; alpha: number
    }> = []

    function resize() {
      const rect = canvas.parentElement!.getBoundingClientRect()
      w = canvas.width = rect.width
      h = canvas.height = rect.height
    }

    function init() {
      resize()
      const accent = getComputedStyle(document.documentElement)
        .getPropertyValue('--theme-accent').trim()
      particles = Array.from({ length: 40 }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        r: Math.random() * 2 + 1,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        alpha: Math.random() * 0.5 + 0.1,
      }))
    }

    function draw() {
      ctx.clearRect(0, 0, w, h)
      const accent = getComputedStyle(document.documentElement)
        .getPropertyValue('--theme-accent').trim()

      for (const p of particles) {
        p.x += p.vx
        p.y += p.vy

        if (p.x < 0) p.x = w
        if (p.x > w) p.x = 0
        if (p.y < 0) p.y = h
        if (p.y > h) p.y = 0

        ctx.beginPath()
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2)
        ctx.fillStyle = accent
        ctx.globalAlpha = p.alpha
        ctx.fill()
      }

      // Draw connections
      ctx.globalAlpha = 1
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x
          const dy = particles[i].y - particles[j].y
          const dist = Math.sqrt(dx * dx + dy * dy)
          if (dist < 120) {
            ctx.beginPath()
            ctx.moveTo(particles[i].x, particles[i].y)
            ctx.lineTo(particles[j].x, particles[j].y)
            ctx.strokeStyle = accent
            ctx.globalAlpha = 0.06 * (1 - dist / 120)
            ctx.lineWidth = 0.5
            ctx.stroke()
          }
        }
      }
      ctx.globalAlpha = 1
      requestAnimationFrame(draw)
    }

    init()
    draw()
    window.addEventListener('resize', resize)
  }
</script>
