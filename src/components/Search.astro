---
import IconCircleX from '~/icons/circle-x.svg'
import IconSearch from '~/icons/search.svg'

const { trailingSlashes = false } = Astro.props
---

<site-search
  class="ms-auto"
  id="search"
  data-trailing-slashes={trailingSlashes}
  data-base-url={import.meta.env.BASE_URL}
  data-dev={import.meta.env.DEV}
>
  <button
    class="flex size-9 cursor-pointer items-center justify-center text-foreground/70 transition-colors hover:text-foreground"
    aria-keyshortcuts="Control+K Meta+K"
    title="搜尋文章"
    data-open-modal
    disabled
  >
    <IconSearch class="size-5" />
    <span class="sr-only">Open Search</span>
  </button>
  <dialog
    aria-label="search"
    class="text-foreground! bg-background max-h-5/6 min-h-48 w-7/8 sm:w-5/6 max-w-xl border! border-foreground/15 shadow-xl backdrop:backdrop-blur-sm open:flex mx-auto mt-10 sm:mt-16 mb-auto rounded-lg"
  >
    <div class="dialog-frame flex grow flex-col gap-4 p-6 pt-6 max-w-full">
      <button class="cursor-pointer fixed top-2 right-2 rounded-full" data-close-modal>
        <IconCircleX class="size-6 text-accent/50" />
      </button>
      {
        import.meta.env.DEV ? (
          <div class="mx-auto text-center">
            <p>
              Search is only available in production builds. <br />
              Try building and previewing the site to test it out locally.
            </p>
          </div>
        ) : (
          <div class="search-container">
            <div class="py-8 text-center text-sm text-foreground/60" data-search-loading>
              載入搜尋…
            </div>
            <div id="pagefind-search" class="max-w-full" />
          </div>
        )
      }
    </div>
  </dialog>
</site-search>

<style is:global>
  :root {
    --pagefind-ui-font: inherit;
    --pagefind-ui-primary: var(--theme-accent);
    --pagefind-ui-text: var(--theme-foreground);
    --pagefind-ui-background: var(--theme-background);
    --pagefind-ui-border: var(--theme-accent);
    --pagefind-ui-border-width: 2px;
  }

  .pagefind-ui__results-area {
    margin: 16px 0;
  }
  .pagefind-ui__result {
    overflow-x: scroll !important;
  }

  .pagefind-ui__result-inner {
    max-width: 100% !important;
  }

  .pagefind-ui__result-inner mark {
    background-color: var(--theme-accent) !important;
    color: var(--theme-background) !important;
    font-weight: 600 !important;
    padding: 0 3px !important;
    border-radius: 6px !important;
  }

  .pagefind-ui__result-nested .pagefind-ui__result-link:before {
    content: '>' !important;
    left: -16px !important;
    right: unset !important;
    color: var(--theme-accent) !important;
    font-weight: 600 !important;
  }
</style>

<script is:inline>
  class SiteSearch extends HTMLElement {
    #closeBtn
    #dialog
    #dialogFrame
    #openBtn
    #controller
    #searchReady
    #baseUrl
    #isDev

    constructor() {
      super()
      this.#openBtn = this.querySelector('button[data-open-modal]')
      this.#closeBtn = this.querySelector('button[data-close-modal]')
      this.#dialog = this.querySelector('dialog')
      this.#dialogFrame = this.querySelector('.dialog-frame')
      this.#controller = new AbortController()
      this.#searchReady = null
      this.#baseUrl = this.dataset.baseUrl || '/'
      this.#isDev = this.dataset.dev === 'true'

      this.trailingSlashes = this.dataset.trailingSlashes === 'true'
      this.stripTrailingSlash = (path) => path.replace(/(.)\/(#.*)?$/, '$1$2')
      this.formatURL = !this.trailingSlashes ? this.stripTrailingSlash : (path) => path

      // Set up events
      if (this.#openBtn) {
        this.#openBtn.addEventListener('click', this.openModal)
        this.#openBtn.disabled = false
      } else {
        console.warn('Search button not found')
      }

      if (this.#closeBtn) {
        this.#closeBtn.addEventListener('click', this.closeModal)
      } else {
        console.warn('Close button not found')
      }

      if (this.#dialog) {
        this.#dialog.addEventListener('close', () => {
          window.removeEventListener('click', this.onWindowClick)
          const body = document.querySelector('body')
          body?.classList.remove('overflow-hidden')
        })
      } else {
        console.warn('Dialog not found')
      }
    }

    #loadPagefindStyles = () =>
      new Promise((resolve, reject) => {
        const existing = document.querySelector('link[data-pagefind-styles]')
        if (existing?.sheet) {
          resolve()
          return
        }

        const stylesheet = existing ?? document.createElement('link')
        stylesheet.rel = 'stylesheet'
        stylesheet.href = this.#baseUrl.replace(/\/$/, '') + '/pagefind/pagefind-ui.css'
        stylesheet.dataset.pagefindStyles = ''
        stylesheet.addEventListener('load', () => resolve(), { once: true })
        stylesheet.addEventListener(
          'error',
          () => reject(new Error('Pagefind styles failed')),
          {
            once: true,
          },
        )
        if (!existing) document.head.appendChild(stylesheet)
      })

    #loadPagefindScript = () =>
      new Promise((resolve, reject) => {
        if (window.PagefindUI) {
          resolve()
          return
        }

        const existing = document.querySelector('script[data-pagefind-script]')
        const script = existing ?? document.createElement('script')
        script.src = this.#baseUrl.replace(/\/$/, '') + '/pagefind/pagefind-ui.js'
        script.dataset.pagefindScript = ''
        script.async = true
        script.addEventListener(
          'load',
          () =>
            window.PagefindUI
              ? resolve()
              : reject(new Error('Pagefind UI failed to initialize')),
          { once: true },
        )
        script.addEventListener(
          'error',
          () => reject(new Error('Pagefind UI failed to load')),
          { once: true },
        )
        if (!existing) document.head.appendChild(script)
      })

    #initializeSearch = () => {
      if (this.#isDev) return Promise.resolve()
      if (this.#searchReady) return this.#searchReady

      this.#searchReady = (async () => {
        await Promise.all([this.#loadPagefindStyles(), this.#loadPagefindScript()])
        const PagefindUI = window.PagefindUI
        if (!PagefindUI) throw new Error('Pagefind UI is unavailable')

        new PagefindUI({
          baseUrl: this.#baseUrl,
          bundlePath: this.#baseUrl.replace(/\/$/, '') + '/pagefind/',
          element: '#pagefind-search',
          showImages: false,
          showSubResults: true,
          processResult: (result) => {
            // Ensure links in search results match the trailing slashes setting
            result.url = this.formatURL(result.url)

            result.sub_results = result.sub_results.map((res) => {
              res.url = this.formatURL(res.url)
              return res
            })

            return result
          },
        })
        this.querySelector('[data-search-loading]')?.remove()
      })()

      return this.#searchReady
    }

    connectedCallback() {
      // window events, requires cleanup
      window.addEventListener('keydown', this.onWindowKeydown, {
        signal: this.#controller.signal,
      })
    }

    disconnectedCallback() {
      this.#controller.abort()
    }

    openModal = async (event) => {
      if (!this.#dialog) {
        console.warn('Dialog not found')
        return
      }

      const body = document.querySelector('body')
      body?.classList.add('overflow-hidden')

      this.#dialog.showModal()
      event?.stopPropagation()
      window.addEventListener('click', this.onWindowClick, {
        signal: this.#controller.signal,
      })

      try {
        await this.#initializeSearch()
        this.querySelector('input')?.focus()
      } catch (error) {
        console.error('Search failed to load', error)
        const loadingMessage = this.querySelector('[data-search-loading]')
        if (loadingMessage)
          loadingMessage.textContent = '搜尋載入失敗，請重新整理後再試。'
      }
    }

    closeModal = () => {
      this.#dialog?.close()
    }

    onWindowClick = (event) => {
      // check if it's a link
      const isLink = 'href' in (event.target || {})
      // make sure the click is either a link or outside of the dialog
      if (
        isLink ||
        (document.body.contains(event.target) &&
          !this.#dialogFrame?.contains(event.target))
      ) {
        this.closeModal()
      }
    }

    onWindowKeydown = (e) => {
      if (!this.#dialog) {
        console.warn('Dialog not found')
        return
      }
      // check if it's the Control+K or ⌘+K shortcut
      if ((e.metaKey === true || e.ctrlKey === true) && e.key === 'k') {
        this.#dialog.open ? this.closeModal() : void this.openModal(e)
        e.preventDefault()
      }
    }
  }

  if (!customElements.get('site-search')) customElements.define('site-search', SiteSearch)
</script>
