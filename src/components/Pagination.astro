---
import IconChevronsLeft from '~/icons/chevrons-left.svg'
import IconChevronsRight from '~/icons/chevrons-right.svg'

interface Props {
  prevLink?: string
  prevText?: string
  nextLink?: string
  nextText?: string
  bare?: boolean
}

const { prevLink, prevText, nextLink, nextText, bare = false } = Astro.props
---

<nav
  class:list={[
    'flex flex-row flex-wrap gap-3',
    bare ? 'mt-4' : 'mt-10 border-t border-foreground/10 pt-8',
  ]}
  aria-label="文章分頁"
>
  {
    prevLink && (
      <a
        href={prevLink}
        aria-label="Previous Page"
        class="button flex-row items-center justify-center w-full !pr-3.5 sm:w-auto"
      >
        <IconChevronsLeft class="mr-2 text-xl size-5" />
        {prevText || 'Previous'}
      </a>
    )
  }
  {
    nextLink && (
      <a
        href={nextLink}
        aria-label="Next Page"
        class="button flex-row items-center justify-center w-full !pl-3.5 sm:w-auto ml-auto"
      >
        {nextText || 'Next'}
        <IconChevronsRight class="ml-2 text-xl size-5" />
      </a>
    )
  }
</nav>
