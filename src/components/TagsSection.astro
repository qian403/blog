---
import type { CollectionEntry } from 'astro:content'
import { TagsGroup } from '~/utils'

interface Props {
  posts: CollectionEntry<'posts'>[]
}

const { posts } = Astro.props
const tagsGroup = await TagsGroup.build(posts)
---

<ul
  class="grid gap-px overflow-hidden rounded-lg border border-foreground/10 bg-foreground/10 sm:grid-cols-2 lg:grid-cols-3"
>
  {
    tagsGroup.sortCollationsLargest().map((tag) => (
      <li class="bg-background" data-tag-item data-tag-name={tag.title}>
        <a
          href={tag.url}
          class="group flex min-h-20 items-center justify-between gap-4 p-5 no-underline transition-colors hover:bg-accent/5"
        >
          <span class="min-w-0 font-semibold text-foreground transition-colors before:mr-0.5 before:text-accent before:content-['#'] group-hover:text-accent">
            {tag.title}
          </span>
          <span class="shrink-0 font-mono text-xs text-foreground/65">
            {tag.entries.length}
          </span>
        </a>
      </li>
    ))
  }
</ul>
