---
import type { FrontmatterImage } from '~/types'
import { Image } from 'astro:assets'

interface Props {
  avatarImage?: FrontmatterImage
}
const { avatarImage } = Astro.props
---

<div
  class="mx-auto mt-14 flex max-w-[760px] flex-col items-center gap-6 border-y border-foreground/10 py-9 text-center sm:flex-row sm:text-left"
>
  {
    avatarImage && (
      <Image
        src={avatarImage.src}
        alt={avatarImage.alt}
        class="size-20 shrink-0 rounded-full border border-foreground/10 object-cover"
        widths={[80, 160]}
        height={80}
        width={80}
      />
    )
  }
  <div class="min-w-0">
    <div class="prose text-base/7 text-foreground/68">
      <slot />
    </div>
  </div>
</div>

<style>
  .prose :global(p) {
    margin: 0;
  }
</style>
