---
/**
 * StructuredData Component
 * 生成 JSON-LD 結構化數據以增強 SEO
 * 支援 WebSite、Blog、BlogPosting、CollectionPage、ProfilePage 等 Schema.org 類型
 */
import siteConfig from '~/site.config'

type PageType = 'website' | 'article' | 'collection' | 'profile' | 'page'

interface BreadcrumbItem {
  name: string
  item: string
}

interface ItemListEntry {
  name: string
  url: string
}

interface Props {
  pageType: PageType
  title?: string
  description?: string
  author?: string
  publishDate?: Date
  modifiedDate?: Date
  image?: string
  url: string
  tags?: string[]
  breadcrumbs?: BreadcrumbItem[]
  itemList?: ItemListEntry[]
}

const {
  pageType,
  title,
  description,
  author,
  publishDate,
  modifiedDate,
  image,
  url,
  tags,
  breadcrumbs,
  itemList,
} = Astro.props

const socialProfiles = Object.values(siteConfig.socialLinks).filter(
  (value): value is string => typeof value === 'string',
)
const normalizedSite = siteConfig.site.replace(/\/$/, '')
const personId = `${normalizedSite}/#person`
const websiteId = `${normalizedSite}/#website`
const blogId = `${normalizedSite}/#blog`
const breadcrumbId = `${url}#breadcrumb`
const itemListId = `${url}#item-list`

const personSchema = {
  '@id': personId,
  '@type': 'Person',
  name: siteConfig.author,
  url: `${normalizedSite}/about/`,
  sameAs: socialProfiles.length > 0 ? socialProfiles : undefined,
}

const websiteSchema = {
  '@id': websiteId,
  '@type': 'WebSite',
  name: siteConfig.title,
  description: siteConfig.description,
  url: `${normalizedSite}/`,
  inLanguage: 'zh-TW',
  publisher: { '@id': personId },
}

const blogSchema = {
  '@id': blogId,
  '@type': 'Blog',
  name: siteConfig.title,
  description: siteConfig.description,
  url: `${normalizedSite}/`,
  isPartOf: { '@id': websiteId },
  author: { '@id': personId },
  publisher: { '@id': personId },
  inLanguage: 'zh-TW',
}

const articleAuthor =
  !author || author === siteConfig.author
    ? { '@id': personId }
    : { '@type': 'Person', name: author }

const articleSchema =
  pageType === 'article'
    ? {
        '@id': `${url}#article`,
        '@type': 'BlogPosting',
        headline: title,
        description: description || siteConfig.description,
        image: image || `${siteConfig.site}/social-cards/__default.png`,
        datePublished: publishDate?.toISOString(),
        dateModified: (modifiedDate || publishDate)?.toISOString(),
        author: articleAuthor,
        publisher: { '@id': personId },
        isPartOf: { '@id': blogId },
        mainEntityOfPage: {
          '@id': url,
        },
        breadcrumb: breadcrumbs?.length ? { '@id': breadcrumbId } : undefined,
        url,
        inLanguage: 'zh-TW',
        keywords: tags?.join(', ') || siteConfig.tags.join(', '),
      }
    : null

const collectionSchema =
  pageType === 'collection'
    ? {
        '@id': url,
        '@type': 'CollectionPage',
        name: title || siteConfig.title,
        description: description || siteConfig.description,
        url,
        inLanguage: 'zh-TW',
        isPartOf: { '@id': websiteId },
        mainEntity: itemList?.length ? { '@id': itemListId } : undefined,
        breadcrumb: breadcrumbs?.length ? { '@id': breadcrumbId } : undefined,
      }
    : null

const itemListSchema =
  pageType === 'collection' && itemList && itemList.length > 0
    ? {
        '@id': itemListId,
        '@type': 'ItemList',
        itemListElement: itemList.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.name,
          url: item.url,
        })),
      }
    : null

const profileSchema =
  pageType === 'profile'
    ? {
        '@id': url,
        '@type': 'ProfilePage',
        name: title || siteConfig.author,
        description: description || siteConfig.description,
        url,
        inLanguage: 'zh-TW',
        isPartOf: { '@id': websiteId },
        mainEntity: { '@id': personId },
        breadcrumb: breadcrumbs?.length ? { '@id': breadcrumbId } : undefined,
      }
    : null

const webPageSchema =
  pageType === 'page'
    ? {
        '@id': url,
        '@type': 'WebPage',
        name: title || siteConfig.title,
        description: description || siteConfig.description,
        url,
        inLanguage: 'zh-TW',
        isPartOf: { '@id': websiteId },
        breadcrumb: breadcrumbs?.length ? { '@id': breadcrumbId } : undefined,
      }
    : null

const breadcrumbSchema =
  breadcrumbs && breadcrumbs.length > 0
    ? {
        '@id': breadcrumbId,
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((breadcrumb, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: breadcrumb.name,
          item: breadcrumb.item,
        })),
      }
    : null

const graph = [
  personSchema,
  websiteSchema,
  blogSchema,
  articleSchema,
  collectionSchema,
  itemListSchema,
  profileSchema,
  webPageSchema,
  breadcrumbSchema,
].filter(Boolean)

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': graph,
}
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
