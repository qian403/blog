---
/**
 * StructuredData Component
 * 生成 JSON-LD 結構化數據以增強 SEO
 * 支援 WebSite、Blog、BlogPosting、CollectionPage、ProfilePage 等 Schema.org 類型
 */
import siteConfig from '~/site.config'

type PageType = 'website' | 'article' | 'collection' | 'profile' | 'page'

interface BreadcrumbItem {
  name: string
  item: string
}

interface ItemListEntry {
  name: string
  url: string
}

interface Props {
  pageType: PageType
  title?: string
  description?: string
  author?: string
  publishDate?: Date
  modifiedDate?: Date
  image?: string
  url: string
  tags?: string[]
  breadcrumbs?: BreadcrumbItem[]
  itemList?: ItemListEntry[]
}

const {
  pageType,
  title,
  description,
  author,
  publishDate,
  modifiedDate,
  image,
  url,
  tags,
  breadcrumbs,
  itemList,
} = Astro.props

const socialProfiles = Object.values(siteConfig.socialLinks).filter(
  (value): value is string => typeof value === 'string',
)

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteConfig.author,
  url: siteConfig.site,
  sameAs: socialProfiles.length > 0 ? socialProfiles : undefined,
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.title,
  description: siteConfig.description,
  url: siteConfig.site,
  inLanguage: 'zh-TW',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteConfig.site}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
}

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: siteConfig.title,
  description: siteConfig.description,
  url: siteConfig.site,
  author: {
    '@type': 'Person',
    name: siteConfig.author,
  },
  inLanguage: 'zh-TW',
}

const articleSchema =
  pageType === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description: description || siteConfig.description,
        image: image || `${siteConfig.site}/social-cards/__default.png`,
        datePublished: publishDate?.toISOString(),
        dateModified: (modifiedDate || publishDate)?.toISOString(),
        author: {
          '@type': 'Person',
          name: author || siteConfig.author,
        },
        publisher: {
          '@type': 'Organization',
          name: siteConfig.title,
          logo: {
            '@type': 'ImageObject',
            url: `${siteConfig.site}/favicon.ico`,
          },
        },
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': url,
        },
        url,
        inLanguage: 'zh-TW',
        keywords: tags?.join(', ') || siteConfig.tags.join(', '),
      }
    : null

const collectionSchema =
  pageType === 'collection'
    ? {
        '@context': 'https://schema.org',
        '@type': 'CollectionPage',
        name: title || siteConfig.title,
        description: description || siteConfig.description,
        url,
        inLanguage: 'zh-TW',
        isPartOf: {
          '@type': 'WebSite',
          name: siteConfig.title,
          url: siteConfig.site,
        },
      }
    : null

const itemListSchema =
  pageType === 'collection' && itemList && itemList.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'ItemList',
        itemListElement: itemList.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.name,
          url: item.url,
        })),
      }
    : null

const profileSchema =
  pageType === 'profile'
    ? {
        '@context': 'https://schema.org',
        '@type': 'ProfilePage',
        name: title || siteConfig.author,
        description: description || siteConfig.description,
        url,
        inLanguage: 'zh-TW',
        mainEntity: {
          '@type': 'Person',
          name: siteConfig.author,
          url: siteConfig.site,
          sameAs: socialProfiles.length > 0 ? socialProfiles : undefined,
        },
      }
    : null

const webPageSchema =
  pageType === 'page'
    ? {
        '@context': 'https://schema.org',
        '@type': 'WebPage',
        name: title || siteConfig.title,
        description: description || siteConfig.description,
        url,
        inLanguage: 'zh-TW',
      }
    : null

const breadcrumbSchema =
  breadcrumbs && breadcrumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((breadcrumb, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: breadcrumb.name,
          item: breadcrumb.item,
        })),
      }
    : null

const schemas = [
  pageType === 'website' ? websiteSchema : null,
  pageType === 'website' ? blogSchema : null,
  pageType === 'website' ? personSchema : null,
  articleSchema,
  collectionSchema,
  itemListSchema,
  profileSchema,
  pageType === 'profile' ? personSchema : null,
  webPageSchema,
  breadcrumbSchema,
].filter(Boolean)
---

{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
