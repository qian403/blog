---
import siteConfig from '~/site.config'
import LightDarkAutoButton from '~/components/LightDarkAutoButton.astro'
import Search from '~/components/Search.astro'
import NavLink from '~/components/NavLink.astro'

const binaryTheme = siteConfig.themes.include.length === 2
---

<header
  class="site-header sticky top-0 z-40 border-b border-foreground/10 bg-background/92 backdrop-blur-md"
>
  <div class="relative flex h-16 items-center justify-between gap-4">
    <a id="logo" href="/" class="flex min-w-0 items-baseline gap-2 no-underline">
      <span class="text-lg font-bold text-foreground">CHIEN</span>
      <span class="hidden text-xs font-semibold uppercase text-foreground/65 sm:inline"
        >Tech Notes</span
      >
    </a>
    <div class="flex items-center gap-3">
      <nav aria-label="主要導覽" class="hidden md:block">
        <ul class="flex items-center gap-6 text-sm text-foreground/70">
          {
            siteConfig.navLinks.map((link) => (
              <li>
                <NavLink link={link} />
              </li>
            ))
          }
        </ul>
      </nav>
      <Search trailingSlashes={siteConfig.trailingSlashes} />
      {binaryTheme && <LightDarkAutoButton />}
      <nav id="nav-mobile" aria-label="行動版導覽" class="p-0 md:hidden">
        <button
          id="nav-mobile-button"
          class="flex size-9 items-center justify-center text-xl text-foreground/75"
          type="button"
          aria-expanded="false"
          aria-controls="nav-mobile-list"
          aria-label="開啟選單"
        >
          ☰
        </button>
        <ul
          id="nav-mobile-list"
          class="invisible absolute right-0 top-14 z-50 flex min-w-44 flex-col gap-1 rounded-lg border border-foreground/10 bg-background p-2 shadow-xl"
        >
          {
            siteConfig.navLinks.map((link) => (
              <li class="px-3 py-2" aria-expanded="false">
                <NavLink link={link} />
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  const navMobileButton = document.getElementById('nav-mobile-button')
  const navMobileList = document.getElementById('nav-mobile-list')
  const navMobileListItems = navMobileList?.querySelectorAll('li')
  const toggleNavMobileMenu = (action: 'on' | 'off' | 'toggle') => {
    let isNowOpen: boolean = false
    if (action === 'on') {
      isNowOpen = true
      navMobileList?.classList.remove('invisible')
    } else if (action === 'off') {
      isNowOpen = false
      navMobileList?.classList.add('invisible')
    } else {
      isNowOpen = !navMobileList?.classList.toggle('invisible')
    }
    navMobileButton?.setAttribute('aria-expanded', isNowOpen ? 'true' : 'false')
    navMobileButton?.setAttribute('aria-label', isNowOpen ? '關閉選單' : '開啟選單')
    navMobileListItems?.forEach((listItem) => {
      listItem.setAttribute('aria-expanded', isNowOpen ? 'true' : 'false')
    })
  }
  navMobileButton?.addEventListener('click', (_ev) => {
    toggleNavMobileMenu('toggle')
  })
</script>
