---
import siteConfig from '~/site.config'
import SocialLinks from '~/components/SocialLinks.astro'
---

<footer
  class="mt-20 flex max-w-full grow-0 flex-col gap-7 border-t border-foreground/10 py-10 text-sm text-foreground/65 md:mt-28 md:flex-row md:items-end md:justify-between"
>
  <div>
    <p class="font-semibold text-foreground">CHIEN 的技術筆記</p>
    <p class="mt-2">Network, security and systems in practice.</p>
  </div>
  <div class="flex flex-col gap-5 md:items-end">
    {siteConfig.socialLinks && <SocialLinks socialLinks={siteConfig.socialLinks} />}
    <p>{siteConfig.author} © 2026 · Built with Astro</p>
  </div>
</footer>
