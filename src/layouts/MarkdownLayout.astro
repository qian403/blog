---
import Layout from '~/layouts/Layout.astro'
import type { MarkdownLayoutProps } from 'astro'

type Props = MarkdownLayoutProps<{
  // Define frontmatter props here
  title: string
  description?: string
  pageType?: 'profile' | 'page' | 'collection'
  noindex?: boolean
}>

// Now, `frontmatter`, `url`, and other Markdown layout properties
// are accessible with type safety
const { frontmatter } = Astro.props
---

<Layout
  title={frontmatter.title}
  description={frontmatter.description}
  pageType={frontmatter.pageType || 'page'}
  noindex={frontmatter.noindex}
  wide
>
  <article class="mx-auto w-full max-w-[760px] py-12 sm:py-16">
    <header class="mb-12 border-b border-foreground/10 pb-10">
      <p class="mb-5 font-mono text-xs font-semibold uppercase text-accent">
        Markdown preview
      </p>
      <h1 class="text-4xl font-bold leading-tight text-heading1 sm:text-5xl">
        {frontmatter.title}
      </h1>
      {
        frontmatter.description && (
          <p class="mt-6 text-lg/8 text-foreground/65">{frontmatter.description}</p>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Layout>
